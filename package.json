{
  "name": "eslint-plugin-effect-locality",
  "version": "0.1.0",
  "description": "ESLint rules that enforce FP discipline around effectful APIs in TypeScript codebases. Working name; see README for naming discussion.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "lint": "npm run build && eslint .",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build"
  },
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "functional-programming",
    "purity",
    "effects",
    "typescript"
  ],
  "license": "MIT",
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "eslint": "^9.18.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
